# All variables below are optional — the server has built-in defaults.

PORT=3005

# Model id is set in the app: Menu → Settings (not in .env).

# Provider chat-completions URL. Omit to use the built-in default in server.ts.
# AI_API_URL=https://api.vsellm.ru/v1/chat/completions

# Docker + Traefik (deploy only): hostname must match DNS.
# APP_HOST=chat.example.com

# Docker network Traefik uses (docker network ls).
# TRAEFIK_DOCKER_NETWORK=traefik
