{
  "name": "ai-chat",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "esbuild public/app.ts --bundle --outfile=public/app.js --platform=browser --format=iife --target=es2022 --loader:.wasm=file",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js",
    "dev": "tsc -p tsconfig.server.json --watch & node --watch dist/server.js & esbuild public/app.ts --bundle --outfile=public/app.js --platform=browser --format=iife --target=es2022 --loader:.wasm=file --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jotai": "^2.18.1",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.2"
  }
}
